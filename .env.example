# ============================================================================
# Semantic Career Alignment Engine — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.

# ─── Google Gemini API Key ───────────────────────────────────────────────────
# Used for BOTH embeddings and LLM generation.
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase Configuration (Optional) ──────────────────────────────────────
# Enables the Vector Engine (pgvector) and cloud persistence.
# Get these from: Supabase Dashboard > Project Settings > API
# The "Project URL" — looks like https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# The "anon / public" key (safe for client-side usage)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
